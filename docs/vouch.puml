@startuml
skinparam backgroundColor #ffffff
skinparam defaultFontSize 13
skinparam roundcorner 8
skinparam activityBorderColor #444444
skinparam activityArrowColor #333333

title CivicTrust — QR Vouch Flow

|#dae8fc|Vouchee (receives vouch)|
start
:Open profile page;
:Tap "Show QR Code";

|#fff2cc|Frontend|
:Generate QR from vouchee user_id\n(client-side, qrcode.js);
:Display QR on screen;

|#f8cecc|Voucher (gives vouch)|
:Open scan tab;
:Scan QR — decode vouchee_id;

|#fff2cc|Frontend|
:Show "Vouch for [name]?" confirmation;
:Display fraud warning:\n"If this person is found fraudulent\nyour score drops 15 pts";

|#f8cecc|Voucher (gives vouch)|
:Confirm "Yes, I know this person IRL";

|#fff2cc|Frontend|
:POST /api/vouch\n{vouchee_id};

|#e1d5e7|API|
:verifyAuth — validate JWT (voucher);
if (Authenticated?) then (no)
  :Return 401;
  stop
else (yes)
endif

if (voucher.score < 50 (not Verified)?) then (yes)
  :Return 403 — "must be Verified to vouch";
  |#fff2cc|Frontend|
  :Show "You need Verified status to vouch";
  stop
else (no)
endif

if (vouchee_id == voucher.id?) then (yes)
  :Return 400 — "Cannot vouch for yourself";
  stop
else (no)
endif

:Lookup vouchee in Supabase;
if (Vouchee exists?) then (no)
  :Return 404 — "User not found";
  stop
else (yes)
endif

:Rate limit check\n(max 5 vouches / 24h for voucher);
if (Limit reached?) then (yes)
  :Return 429 — "5 per 24h";
  |#fff2cc|Frontend|
  :Show cooldown message;
  stop
else (no)
endif

:Insert vouch row\n(voucher_id, vouchee_id);
if (DB unique constraint fails (23505)?) then (yes)
  :Return 409 — "Already vouched";
  stop
else (no)
endif

:recalculateUserScore(vouchee_id)\n= min(100, verified_claims*15\n+ vouches*10 + gov_vouched*20);
:Update vouchee score + tier;
:Return 201 {new_score, tier};

note right
  Only vouchee score updates.
  Voucher score unchanged (penalty
  only applies if vouchee is later
  flagged as fraudulent).
end note

|#fff2cc|Frontend|
:Supabase Realtime pushes\nnew score to vouchee's device;
:Animate score ring on vouchee device;

stop
@enduml
