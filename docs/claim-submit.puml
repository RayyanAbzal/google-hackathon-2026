@startuml
skinparam backgroundColor #ffffff
skinparam defaultFontSize 13
skinparam roundcorner 8
skinparam activityBorderColor #444444
skinparam activityArrowColor #333333

title CivicTrust — Claim Submission Flow

|#dae8fc|User|
start
:Select claim type\n(identity / credential / work);
:Photograph or upload doc;

|#fff2cc|Frontend|
:Encode image as base64;
:POST /api/claims\n{type, doc_type, image_base64};

|#e1d5e7|API|
:verifyAuth — validate JWT;
if (Authenticated?) then (no)
  :Return 401;
  stop
else (yes)
endif

:Rate limit check\n(max 3 submissions / 10 min per user);
if (Rate limit exceeded?) then (yes)
  :Return 429 — "wait 10 minutes";
  |#fff2cc|Frontend|
  :Show cooldown message;
  stop
else (no)
endif

:SHA-256 hash of image_base64 -> content_hash;
:Global dedup check\n(content_hash exists in ANY claim across all users?);
if (Duplicate?) then (yes)
  :Return 409 — "This document has already been registered";
  |#fff2cc|Frontend|
  :Show rejection message;
  stop
else (no)
endif

if (USE_FALLBACKS = true?) then (yes)
  :Skip Gemini — use mock analysis\n(extracted_name = display_name, confidence = 0.9);
else (no)
  :analyseDocument(image_base64, doc_type)\n-> Gemini Vision;

  |#d5e8d4|Gemini Vision|
  :Extract: extracted_name, doc_type,\ninstitution, confidence score;
  :Return DocumentAnalysis JSON;

  |#e1d5e7|API|
endif

:Name consistency check\n(partial match: display_name contains extracted_name\nor vice versa) AND confidence >= 0.5;
if (Match passes?) then (no)
  :status = "rejected";
  :Insert rejected claim row\n(stored for audit trail);
  :Return 422 — "name does not match\nor document unreadable";
  |#fff2cc|Frontend|
  :Show rejection reason;
  stop
else (yes)
  :status = "verified";
  :Insert verified claim row;
endif

:recalculateUserScore(user_id)\n= min(100, verified_claims*15\n+ vouches*10 + gov_vouched*20);
:Update user row (score, tier);
:Return 201\n{claim, new_score, tier};

|#fff2cc|Frontend|
:Animate score ring to new value;
:Show success toast + claim in list;

|#dae8fc|User|
:See updated score and verified claim;

stop
@enduml
