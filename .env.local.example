# Copy this to .env.local and fill in real values.
# Never commit .env.local — it's in .gitignore.

# Supabase (get from: supabase.com > project > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # server-side only (seed scripts)

# Gemini (get from: aistudio.google.com > API keys)
GEMINI_API_KEY=your_gemini_api_key

# Demo fallback toggle — set to true if any API fails during demo
USE_FALLBACKS=false
